---
// GameBanner.astro — banner cliccabile di un gioco (porta alla pagina del gioco).
// bannerComplete: se true, l'immagine contiene GIA' nome/testo/bottone,
// quindi mostriamo solo l'immagine senza scriverci sopra nulla.
const { slug, name, thumb = "gt-genshin", emoji = "🎮", tagline = "", image, bannerComplete = false, genre = "" } = Astro.props;
---

<a href={`/giochi/${slug}`} class="game-banner" aria-label={name} data-genre={genre}>
  <div class={`game-banner-bg ${image ? "" : thumb}`} style={image ? `background-image:url('${image}')` : ""}></div>

  {!bannerComplete && (
    <>
      <div class="game-banner-overlay"></div>
      <div class="game-banner-content">
        <div class="game-banner-name">{name}</div>
        <span class="game-banner-go">Vedi guide <i class="fas fa-arrow-right"></i></span>
      </div>
    </>
  )}
</a>
