---
// Navbar.astro — barra di navigazione in cima a ogni pagina.
// Prop "current": indica quale link evidenziare (es. "home", "guide"...).
import { games } from "../data/games";
import { getCollection } from "astro:content";

const { current = "home" } = Astro.props;

const links = [
  { label: "Home",      href: "/",          key: "home" },
  { label: "Giochi",    href: "/giochi",    key: "giochi" },
  { label: "News",      href: "/news",      key: "news" },
  { label: "Community", href: "/community", key: "community" },
  { label: "About",     href: "/about",     key: "about" },
];

// Indice di ricerca: giochi + contenuti. "s" = testo cercabile (nome + alias + gioco).
const guides = await getCollection("guide");
const builds = await getCollection("build");
const aliasBlob = (gameName: string) => {
  const g = games.find((x) => x.name === gameName);
  return g ? [g.name, ...(g.aliases ?? [])].join(" ") : gameName;
};
const searchIndex = [
  ...games.map((g) => ({
    t: g.name,
    u: `/giochi/${g.slug}`,
    k: "Gioco",
    s: [g.name, ...(g.aliases ?? [])].join(" ").toLowerCase(),
  })),
  ...[...guides, ...builds].map((e) => ({
    t: e.data.title,
    u: `/${e.collection}/${e.id}`,
    k: e.data.category,
    s: `${e.data.title} ${aliasBlob(e.data.game)}`.toLowerCase(),
  })),
];
---

<nav class="navbar">
  <a href="/" class="nav-logo">
    <span class="nav-logo-crown">👑</span>
    <span class="nav-logo-text"><span class="k">Kore</span><span class="r">Rift</span></span>
  </a>

  <ul class="nav-links">
    {links.map((l) => (
      <li><a href={l.href} class={current === l.key ? "active" : ""}>{l.label}</a></li>
    ))}
  </ul>

  <div class="nav-search">
    <i class="fas fa-search"></i>
    <input type="text" class="search-input" placeholder="Cerca guide, giochi, build…" autocomplete="off" aria-label="Cerca" />
    <div class="search-results"></div>
  </div>

  <div class="nav-right">
    <a href="/" class="nav-logo-badge" aria-label="KoreRift home">
      <img src="/kr-logo.png" alt="KoreRift" />
    </a>
  </div>

  <button class="hamburger" id="hamburger" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <div class="nav-search nav-search--mobile">
    <i class="fas fa-search"></i>
    <input type="text" class="search-input" placeholder="Cerca guide, giochi, build…" autocomplete="off" aria-label="Cerca" />
    <div class="search-results"></div>
  </div>
  <ul>
    {links.map((l) => (
      <li><a href={l.href}>{l.label}</a></li>
    ))}
  </ul>
</div>

<script type="application/json" id="searchData" is:inline set:html={JSON.stringify(searchIndex)}></script>

<script>
  // Re-inizializza navbar (menu + ricerca) a ogni caricamento/transizione di pagina.
  function initNavbar() {
    const hamburger = document.getElementById("hamburger");
    const mobileMenu = document.getElementById("mobileMenu");
    if (hamburger && !hamburger.dataset.bound) {
      hamburger.dataset.bound = "1";
      hamburger.addEventListener("click", () => {
        hamburger.classList.toggle("open");
        mobileMenu?.classList.toggle("open");
      });
    }

    const dataEl = document.getElementById("searchData");
    const index = dataEl ? JSON.parse(dataEl.textContent || "[]") : [];
    document.querySelectorAll(".nav-search").forEach((boxEl) => {
      const input = boxEl.querySelector(".search-input") as HTMLInputElement | null;
      const box = boxEl.querySelector(".search-results") as HTMLElement | null;
      if (!input || !box || input.dataset.bound) return;
      input.dataset.bound = "1";
      const render = () => {
        const q = input.value.trim().toLowerCase();
        if (!q) { box.classList.remove("open"); box.innerHTML = ""; return; }
        const hits = index.filter((it: any) => it.s.includes(q)).slice(0, 8);
        box.innerHTML = hits.length
          ? hits.map((m: any) => `<a href="${m.u}"><span class="sr-kind">${m.k}</span><span class="sr-title">${m.t}</span></a>`).join("")
          : `<div class="sr-empty">Nessun risultato</div>`;
        box.classList.add("open");
      };
      input.addEventListener("input", render);
      input.addEventListener("focus", render);
      input.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
          const first = box.querySelector("a");
          if (first) window.location.href = first.getAttribute("href")!;
        } else if (e.key === "Escape") box.classList.remove("open");
      });
      input.addEventListener("blur", () => setTimeout(() => box.classList.remove("open"), 150));
    });
  }
  document.addEventListener("astro:page-load", initNavbar);
</script>
