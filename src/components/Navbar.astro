---
// Navbar.astro — barra di navigazione in cima a ogni pagina.
// Prop "current": indica quale link evidenziare (es. "home", "guide"...).
import { games } from "../data/games";
import { getCollection } from "astro:content";

const { current = "home" } = Astro.props;

const links = [
  { label: "Home",      href: "/",          key: "home" },
  { label: "Giochi",    href: "/giochi",    key: "giochi" },
  { label: "News",      href: "/news",      key: "news" },
  { label: "Community", href: "/community", key: "community" },
  { label: "About",     href: "/about",     key: "about" },
];

// Indice di ricerca: giochi + contenuti. "s" = testo cercabile (nome + alias + gioco).
const guides = await getCollection("guide");
const builds = await getCollection("build");
const aliasBlob = (gameName: string) => {
  const g = games.find((x) => x.name === gameName);
  return g ? [g.name, ...(g.aliases ?? [])].join(" ") : gameName;
};
const searchIndex = [
  ...games.map((g) => ({
    t: g.name,
    u: `/giochi/${g.slug}`,
    k: "Gioco",
    s: [g.name, ...(g.aliases ?? [])].join(" ").toLowerCase(),
  })),
  ...[...guides, ...builds].map((e) => ({
    t: e.data.title,
    u: `/${e.collection}/${e.id}`,
    k: e.data.category,
    s: `${e.data.title} ${aliasBlob(e.data.game)}`.toLowerCase(),
  })),
];
---

<nav class="navbar">
  <a href="/" class="nav-logo">
    <span class="nav-logo-crown">👑</span>
    <span class="nav-logo-text"><span class="k">Kore</span><span class="r">Rift</span></span>
  </a>

  <ul class="nav-links">
    {links.map((l) => (
      <li><a href={l.href} class={current === l.key ? "active" : ""}>{l.label}</a></li>
    ))}
  </ul>

  <div class="nav-search">
    <i class="fas fa-search"></i>
    <input type="text" id="searchInput" placeholder="Cerca guide, giochi, build…" autocomplete="off" />
    <div class="search-results" id="searchResults"></div>
  </div>

  <div class="nav-right">
    <a href="/" class="nav-logo-badge" aria-label="KoreRift home">
      <img src="/kr-logo.png" alt="KoreRift" />
    </a>
  </div>

  <button class="hamburger" id="hamburger" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <ul>
    {links.map((l) => (
      <li><a href={l.href}>{l.label}</a></li>
    ))}
  </ul>
</div>

<script>
  // Apertura/chiusura menu mobile (hamburger)
  const hamburger = document.getElementById("hamburger");
  const mobileMenu = document.getElementById("mobileMenu");
  hamburger?.addEventListener("click", () => {
    hamburger.classList.toggle("open");
    mobileMenu?.classList.toggle("open");
  });
</script>

<script define:vars={{ searchIndex }}>
  // Ricerca lato browser: filtra l'indice e mostra i risultati a tendina.
  const input = document.getElementById("searchInput");
  const box = document.getElementById("searchResults");
  if (input && box) {
    const render = () => {
      const q = input.value.trim().toLowerCase();
      if (!q) { box.classList.remove("open"); box.innerHTML = ""; return; }
      const hits = searchIndex.filter((it) => it.s.includes(q)).slice(0, 8);
      box.innerHTML = hits.length
        ? hits.map((m) => `<a href="${m.u}"><span class="sr-kind">${m.k}</span><span class="sr-title">${m.t}</span></a>`).join("")
        : `<div class="sr-empty">Nessun risultato</div>`;
      box.classList.add("open");
    };
    input.addEventListener("input", render);
    input.addEventListener("focus", render);
    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        const first = box.querySelector("a");
        if (first) window.location.href = first.getAttribute("href");
      } else if (e.key === "Escape") {
        box.classList.remove("open");
      }
    });
    document.addEventListener("click", (e) => {
      if (!e.target.closest(".nav-search")) box.classList.remove("open");
    });
  }
</script>
