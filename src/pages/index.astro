---
import Layout from "../layouts/Layout.astro";
import Ticker from "../components/Ticker.astro";
import ContentCard from "../components/ContentCard.astro";
import ListCard from "../components/ListCard.astro";
import { getCollection } from "astro:content";

// Contenuti dalle collection, ordinati dal più recente.
const byDateDesc = (a, b) => b.data.date.valueOf() - a.data.date.valueOf();
const guides = (await getCollection("guide")).sort(byDateDesc);
const builds = (await getCollection("build")).sort(byDateDesc);

const latestGuides = guides.slice(0, 3);
const trendingBuilds = builds.slice(0, 3);
// Card "in evidenza": i 4 contenuti più recenti (guide + build insieme).
const featured = [...guides, ...builds].sort(byDateDesc).slice(0, 4);
---

<Layout current="home">

  <!-- ══════════════ HERO ══════════════ -->
  <section class="hero" id="home">
    <div class="hero-brush-pink"></div>
    <div class="hero-brush-blue"></div>
    <div class="hero-halftone"></div>

    <svg class="hero-brushes" viewBox="0 0 1400 460" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
      <path d="M580 -20 Q800 80 1050 120 Q1250 150 1420 80" stroke="#FF2EB3" stroke-width="90" fill="none" stroke-linecap="round" opacity=".18"/>
      <path d="M620 200 Q850 160 1100 220 Q1280 260 1420 210" stroke="#1161FF" stroke-width="70" fill="none" stroke-linecap="round" opacity=".15"/>
      <path d="M700 380 Q950 340 1200 400 Q1340 430 1420 390" stroke="#FF2EB3" stroke-width="50" fill="none" stroke-linecap="round" opacity=".12"/>
    </svg>

    <div class="hero-star" style="top:18%;left:48%;font-size:2.2rem;animation:float 3.5s ease-in-out infinite;color:var(--yellow);filter:drop-shadow(0 2px 6px rgba(255,214,0,.5));">★</div>
    <div class="hero-star" style="top:30%;left:55%;font-size:1.4rem;animation:float2 4s ease-in-out infinite;color:#ccc;filter:drop-shadow(0 2px 6px rgba(0,0,0,.15));">✦</div>
    <div class="hero-star" style="bottom:28%;left:50%;font-size:1.8rem;animation:float 5s 1s ease-in-out infinite;color:var(--blue);opacity:.5;">◆</div>

    <div class="hero-left">
      <h1 class="hero-headline">
        <span class="line-black">GUIDE GAMING</span>
        <span class="line-blue">RAPIDE, BUILD</span>
        <span class="line-pink">PULITE, ZERO FILLER</span>
      </h1>
      <p class="hero-sub">
        <i class="fas fa-bolt"></i>
        Guide chiare. Build testate. Community vera.<br>Livella il tuo gameplay con KoreRift.
      </p>
      <div class="hero-btns">
        <a href="/guide" class="btn-hero-dark">Esplora le Guide <i class="fas fa-arrow-right"></i></a>
        <a href="/build" class="btn-hero-blue">Scopri le Build 👑</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="mascot-area">
        <div class="hero-bg-kairo">KR</div>
        <div class="kairo-img-wrap">
          <div class="kairo-placeholder-hero">
            <img src="/kairo.png" alt="Kairo — KoreRift Mascot" class="kairo-real-img" />
          </div>
        </div>
        <div class="kairo-name-label">KaiiRo <span class="kr-pink">⚡</span></div>
        <div class="hero-sticker hs-kairo">
          KaiiRo
          <span>KORERIFT MASCOT</span>
        </div>
        <div class="hero-sticker hs-goodgame">
          GOOD GAME,<br>GOOD VIBES 😊
        </div>
        <div class="hero-sticker hs-riftmode">
          ⏻ RIFT MODE: ON
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════ TICKER 1 ══════════════ -->
  <Ticker
    items={["PLAY", "CREATE", "CONNECT", "ANIME", "GAMING", "TECH", "KORERIFT", "GUIDE RAPIDE", "BUILD PULITE", "ZERO FILLER"]}
    duration={22}
  />

  <!-- ══════════════ CARD ROW (contenuti in evidenza, automatici) ══════════════ -->
  <div class="card-row" id="evidenza">
    <div class="card-row-inner">

      {featured.map((e) => (
        <ContentCard
          href={`/${e.collection}/${e.id}`}
          game={e.data.game}
          title={e.data.title}
          description={e.data.description}
          category={e.data.category}
          thumb={e.data.thumb}
          emoji={e.data.emoji}
          cover={e.data.cover}
        />
      ))}

      <div class="join-card" id="social">
        <p class="join-title">JOIN THE<br><span class="pink">COMMUNITY!</span> 👑</p>
        <div class="join-socials">
          <a href="https://www.tiktok.com/@korerift" target="_blank" rel="noopener" class="join-social js-insta"><i class="fab fa-tiktok"></i></a>
          <a href="https://www.twitch.tv/korerift"   target="_blank" rel="noopener" class="join-social js-twitch"><i class="fab fa-twitch"></i></a>
          <a href="https://www.youtube.com/@Korerift" target="_blank" rel="noopener" class="join-social js-youtube"><i class="fab fa-youtube"></i></a>
          <a href="https://x.com/KoreRift"           target="_blank" rel="noopener" class="join-social js-x"><i class="fab fa-x-twitter"></i></a>
        </div>
        <p class="join-sub">Connettiti. Condividi. Livella insieme.</p>
        <a href="https://www.twitch.tv/korerift" target="_blank" rel="noopener" class="btn-join-discord">
          <i class="fab fa-twitch"></i> ENTRA SU TWITCH &rarr;
        </a>
      </div>

    </div>
  </div>

  <!-- ══════════════ TICKER 2 ══════════════ -->
  <Ticker
    variant="ticker-dark"
    duration={18}
    items={["GAMING NEWS", "ANIME REVIEW", "TECH UPDATES", "TIER LIST", "MANGA DROP", "LIVE STREAM", "COMMUNITY", "FANDOM"]}
  />

  <!-- ══════════════ LATEST GUIDES + BUILDS + STATS ══════════════ -->
  <section class="content-section">
    <div class="content-inner">

      <div>
        <div class="col-header">
          <span class="col-title"><i class="fas fa-bolt"></i>&nbsp; Latest Guides</span>
          <a href="/guide" class="col-vedi-tutte">VEDI TUTTE <i class="fas fa-arrow-right"></i></a>
        </div>

        {latestGuides.length > 0 ? latestGuides.map((g) => (
          <ListCard
            href={`/guide/${g.id}`}
            thumb={g.data.thumb}
            emoji={g.data.emoji}
            game={g.data.game}
            category={g.data.category}
            title={g.data.title}
            date={g.data.date}
            readingTime={g.data.readingTime}
            cover={g.data.cover}
          />
        )) : <p class="empty-note" style="padding:1rem 0;text-align:left">Prime guide in arrivo! 👀</p>}
      </div>

      <div>
        <div class="col-header">
          <span class="col-title" style="color:var(--blue)"><i class="fas fa-fire" style="color:var(--blue)"></i>&nbsp; Trending Builds</span>
          <a href="/build" class="col-vedi-tutte">VEDI TUTTE <i class="fas fa-arrow-right"></i></a>
        </div>

        {trendingBuilds.length > 0 ? trendingBuilds.map((b) => (
          <ListCard
            href={`/build/${b.id}`}
            thumb={b.data.thumb}
            emoji={b.data.emoji}
            game={b.data.game}
            category={b.data.category}
            title={b.data.title}
            date={b.data.date}
            readingTime={b.data.readingTime}
            cover={b.data.cover}
          />
        )) : <p class="empty-note" style="padding:1rem 0;text-align:left">Prime build in arrivo! 👀</p>}
      </div>

      <div class="stats-col">
        <div class="stats-box">
          <p class="stats-title">KORERIFT IN NUMERI 📊</p>
          <div class="stats-grid">
            <div class="stat-item">
              <span class="stat-icon">👥</span>
              <span class="stat-num">128K+</span>
              <span class="stat-label">Rifter Attivi</span>
            </div>
            <div class="stat-item">
              <span class="stat-icon">📖</span>
              <span class="stat-num">2.4K+</span>
              <span class="stat-label">Guide Pubblicate</span>
            </div>
            <div class="stat-item">
              <span class="stat-icon">👑</span>
              <span class="stat-num">9.1M+</span>
              <span class="stat-label">Visite Mensili</span>
            </div>
            <div class="stat-item">
              <span class="stat-icon">⚡</span>
              <span class="stat-num">92%</span>
              <span class="stat-label">Community Voto</span>
            </div>
          </div>

          <div class="stats-live-box">
            <span class="stats-live-dot"></span>
            <span class="stats-live-label">LIVE ORA SU TWITCH</span>
            <a href="https://www.twitch.tv/korerift" target="_blank" rel="noopener" class="stats-live-cta">
              <i class="fab fa-twitch"></i> ENTRA NELLA LIVE →
            </a>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ══════════════ TICKER 3 ══════════════ -->
  <Ticker
    variant="ticker-yellow"
    duration={20}
    items={["FOLLOW US", "@KORERIFT", "TIKTOK", "TWITCH", "YOUTUBE", "JOIN THE CREW", "LEVEL UP"]}
  />

  <!-- ══════════════ TWITCH LIVE EMBED ══════════════ -->
  <section class="live-section" id="live">
    <div class="live-inner">
      <div class="live-pill">
        <span class="live-dot"></span>
        LIVE ORA SU TWITCH
      </div>
      <h2 class="live-headline">🎮 GUARDA LA LIVE</h2>
      <p class="live-sub">Entra nel rift — la diretta di KoreRift è attiva adesso</p>

      <div class="twitch-embed-box">
        <div id="twitch-embed"></div>
      </div>

      <p class="live-note">
        Guarda la live su <a href="https://www.twitch.tv/korerift" target="_blank" rel="noopener">twitch.tv/korerift</a>
      </p>
    </div>
  </section>

  <!-- ══════════════ CONTACT STRIP ══════════════ -->
  <section class="contact-strip" id="contact">
    <h2 class="contact-strip-title">SCRIVICI 📩</h2>
    <p class="contact-strip-sub">Per collaborazioni, press kit, business &amp; crew applications</p>
    <a href="mailto:info@korerift.com" class="contact-email-btn">
      <i class="fas fa-envelope"></i>
      info@korerift.com
    </a>
  </section>

</Layout>

<!-- Embed Twitch (script esterno + inizializzazione, lasciati "inline" perché usano una libreria globale) -->
<script is:inline src="https://embed.twitch.tv/embed/v1.js"></script>
<script is:inline>
  new Twitch.Embed("twitch-embed", {
    width: "100%", height: "100%",
    channel: "korerift", layout: "video",
    autoplay: false, theme: "dark",
    parent: [window.location.hostname || "localhost"]
  });

  // Scroll reveal: le card appaiono con una piccola animazione quando entrano in vista
  const revealItems = document.querySelectorAll(".content-card, .join-card, .list-card, .stats-box");
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        e.target.style.animation = `popIn .45s ${(i % 6) * 0.08}s both`;
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  revealItems.forEach((el) => { el.style.opacity = "0"; io.observe(el); });
</script>
