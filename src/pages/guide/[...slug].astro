---
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import BuildGuideLayout from "../../layouts/BuildGuideLayout.astro";
import { getCollection, render } from "astro:content";
import { gameSlug } from "../../utils/assets";

// getStaticPaths: dice ad Astro QUALI pagine creare (una per ogni guida).
export async function getStaticPaths() {
  const guides = await getCollection("guide");
  return guides.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Le guide "build" usano il template grafico e tornano alla pagina del gioco.
const isBuild = entry.data.layout === "build";
const gameHref = `/giochi/${gameSlug(entry.data.game)}`;
---

{isBuild ? (
  <BuildGuideLayout data={entry.data} backHref={gameHref} backLabel={entry.data.game}>
    <Content />
  </BuildGuideLayout>
) : (
  <ArticleLayout data={entry.data} backHref="/guide" backLabel="Tutte le guide" current="guide">
    <Content />
  </ArticleLayout>
)}
