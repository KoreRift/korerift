---
import Layout from "../../layouts/Layout.astro";
import GameBanner from "../../components/GameBanner.astro";
import { games } from "../../data/games";
import { getCollection } from "astro:content";

// Categorie fisse del filtro (mostrate sempre, anche se vuote).
const categories = ["Gacha", "Moba", "MMO", "Altro"];

// Ordina i giochi per data del contenuto più recente (chi ha la guida/build più nuova va in cima).
const allContent = [...(await getCollection("guide")), ...(await getCollection("build"))];
const latestDate = (gameName: string) => {
  const ds = allContent.filter((e) => e.data.game === gameName).map((e) => e.data.date.valueOf());
  return ds.length ? Math.max(...ds) : 0;
};
const sortedGames = [...games].sort((a, b) => latestDate(b.name) - latestDate(a.name));
---

<Layout title="Giochi — KoreRift" current="giochi">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="page-eyebrow"><i class="fas fa-gamepad"></i> Giochi</div>
      <h1 class="page-title">SCEGLI IL TUO <span class="pink">GIOCO</span></h1>
      <p class="page-subtitle">Clicca un gioco per vedere tutte le guide e le build dedicate.</p>
    </div>
  </header>

  <div class="filter-bar" id="gamesFilter">
    <button class="filter-chip active" data-filter="all">Tutti i giochi</button>
    {categories.map((c) => (
      <button class="filter-chip" data-filter={c}>{c}</button>
    ))}
  </div>

  <div class="games-grid" id="gamesGrid">
    {sortedGames.map((g) => (
      <GameBanner
        slug={g.slug}
        name={g.name}
        thumb={g.thumb}
        emoji={g.emoji}
        tagline={g.tagline}
        image={g.image}
        bannerComplete={g.bannerComplete}
        genre={g.genre}
      />
    ))}
  </div>

  <p class="empty-note" id="gamesEmpty" style="display:none">Nessun gioco in questa categoria, per ora. 🚧</p>
</Layout>

<script>
  // Filtro lato browser. "Tutti i giochi" mostra al massimo i 9 più recenti.
  function initGamesFilter() {
    const MAX_ALL = 9;
    const bar = document.getElementById("gamesFilter");
    const grid = document.getElementById("gamesGrid");
    const empty = document.getElementById("gamesEmpty");
    if (!bar || !grid || bar.dataset.bound) return;
    bar.dataset.bound = "1";
    const chips = bar.querySelectorAll(".filter-chip");
    const cards = Array.from(grid.querySelectorAll(".game-banner"));
    function apply(f: string) {
      let visible = 0;
      cards.forEach((card, i) => {
        const el = card as HTMLElement;
        const show = f === "all" ? i < MAX_ALL : el.dataset.genre === f;
        el.style.display = show ? "" : "none";
        if (show) visible++;
      });
      if (empty) (empty as HTMLElement).style.display = visible === 0 ? "" : "none";
    }
    bar.addEventListener("click", (ev) => {
      const btn = (ev.target as HTMLElement).closest(".filter-chip") as HTMLElement | null;
      if (!btn) return;
      chips.forEach((c) => c.classList.remove("active"));
      btn.classList.add("active");
      apply(btn.dataset.filter!);
    });
    apply("all"); // stato iniziale: solo i 9 più recenti
  }
  document.addEventListener("astro:page-load", initGamesFilter);
</script>
